# Fauna "brain" database. Use the same values as in the repo root fauna.config.yaml
# for local development (e.g. FAUNA_ENDPOINT=http://localhost:8443).
# Copy to .env.local and set FAUNA_SECRET to your database secret.

FAUNA_SECRET=your_fauna_secret
FAUNA_ENDPOINT=http://localhost:8443

# Path to FSL schema file. Used by build:schema-graph.
# Can be absolute (e.g. another repo) or relative to this project root.
# Example (absolute): FAUNA_SCHEMA_PATH=/Users/stone/Documents/APP/next-ewb/schema/main.fsl
# Example (relative): FAUNA_SCHEMA_PATH=schema/main.fsl
FAUNA_SCHEMA_PATH=
